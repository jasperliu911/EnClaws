# EnClaws .env example
#
# Quick start:
# 1) Copy this file to `.env` (for local runs from this repo), OR to `~/.enclaws/.env` (for launchd/systemd daemons).
# 2) Fill only the values you use.
# 3) Keep real secrets out of git.
#
# -----------------------------------------------------------------------------
# Gateway auth + paths
# -----------------------------------------------------------------------------
# Recommended if the gateway binds beyond loopback.
#ENCLAWS_GATEWAY_TOKEN=change-me-to-a-long-random-token
# Example generator: openssl rand -hex 32

# Optional alternative auth mode (use token OR password).
ENCLAWS_GATEWAY_PASSWORD=change-me-to-a-strong-password

# Optional path overrides (defaults shown for reference).
ENCLAWS_STATE_DIR=~/.enclaws
ENCLAWS_HOME=~

# Optional: import missing keys from your login shell profile.
# ENCLAWS_LOAD_SHELL_ENV=1
# ENCLAWS_SHELL_ENV_TIMEOUT_MS=15000

# -----------------------------------------------------------------------------
# Multi-tenant database (PostgreSQL)
# -----------------------------------------------------------------------------
# Required for multi-tenant mode. If not set, runs in single-tenant (legacy) mode.
#ENCLAWS_DB_URL=postgresql://postgres:postgres@localhost:5432/enclaws
#ENCLAWS_DB_HOST=localhost
#ENCLAWS_DB_PORT=5432
#ENCLAWS_DB_NAME=postgres
#ENCLAWS_DB_USER=postgres
#ENCLAWS_DB_SSL=false
#ENCLAWS_DB_POOL_MAX=20

#Upgrade configuration of npm image source
ENCLAWS_NPM_REGISTRY=https://registry.npmjs.org
#Upgrade configuration npm image package name
ENCLAWS_NPM_PACKAGE=enclaws
#Upgrade download URL template for Windows installer mode ({version} will be replaced)
ENCLAWS_UPDATE_DOWNLOAD_URL=https://www.enclaws.ai
#Upgrade download URL template for macOS DMG installer mode ({version} will be replaced)
ENCLAWS_UPDATE_DOWNLOAD_URL_MAC=https://www.enclaws.ai


# sqlite数据库
ENCLAWS_DB_URL=sqlite://~/.enclaws/enclaws.db
# GATEWAY默认端口号
ENCLAWS_GATEWAY_PORT=18888

# Control UI 配置
# 禁用设备身份验证 (true/false, 默认 true)
ENCLAWS_CONTROL_UI_DISABLE_DEVICE_AUTH=true
# 允许的浏览器来源 (逗号分隔, 默认基于 ENCLAWS_GATEWAY_PORT 自动生成)
ENCLAWS_CONTROL_UI_ALLOWED_ORIGINS=http://localhost:18888,http://127.0.0.1:18888

#跟LLM交互的prompt跟踪开关配置
ENCLAWS_TRACE_ENABLED=true

#禁用局域网服务发现
ENCLAWS_DISABLE_BONJOUR=1

# -----------------------------------------------------------------------------
# JWT Authentication (required for multi-tenant mode)
# -----------------------------------------------------------------------------
# Example generator: openssl rand -hex 64
ENCLAWS_JWT_ACCESS_EXPIRES=30m
ENCLAWS_JWT_REFRESH_EXPIRES=7d

# -----------------------------------------------------------------------------
# Model provider API keys (set at least one)
# -----------------------------------------------------------------------------
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# GEMINI_API_KEY=...
# OPENROUTER_API_KEY=sk-or-...
# ENCLAWS_LIVE_OPENAI_KEY=sk-...
# ENCLAWS_LIVE_ANTHROPIC_KEY=sk-ant-...
# ENCLAWS_LIVE_GEMINI_KEY=...
# OPENAI_API_KEY_1=...
# ANTHROPIC_API_KEY_1=...
# GEMINI_API_KEY_1=...
# GOOGLE_API_KEY=...
# OPENAI_API_KEYS=sk-1,sk-2
# ANTHROPIC_API_KEYS=sk-ant-1,sk-ant-2
# GEMINI_API_KEYS=key-1,key-2

# Optional additional providers
# ZAI_API_KEY=...
# AI_GATEWAY_API_KEY=...
# MINIMAX_API_KEY=...
# SYNTHETIC_API_KEY=...

# -----------------------------------------------------------------------------
# Channels (only set what you enable)
# -----------------------------------------------------------------------------
# TELEGRAM_BOT_TOKEN=123456:ABCDEF...
# DISCORD_BOT_TOKEN=...
# SLACK_BOT_TOKEN=xoxb-...
# SLACK_APP_TOKEN=xapp-...

# Optional channel env fallbacks
# MATTERMOST_BOT_TOKEN=...
# MATTERMOST_URL=https://chat.example.com
# ZALO_BOT_TOKEN=...
# ENCLAWS_TWITCH_ACCESS_TOKEN=oauth:...

# -----------------------------------------------------------------------------
# Tools + voice/media (optional)
# -----------------------------------------------------------------------------
# BRAVE_API_KEY=...
# PERPLEXITY_API_KEY=pplx-...
# FIRECRAWL_API_KEY=...

# ELEVENLABS_API_KEY=...
# XI_API_KEY=...  # alias for ElevenLabs
# DEEPGRAM_API_KEY=...

# -----------------------------------------------------------------------------
# Skill pack auto-install (tenant onboarding)
# -----------------------------------------------------------------------------
# 企业创建时自动安装技能包 (true/false, 默认 true)
SKILL_PACK_AUTO_INSTALL=true
# 技能包本地路径（全量安装包内置场景），留空则降级到 git clone
SKILL_PACK_LOCAL_DIR=
# 技能包 git 仓库地址（本地路径不可用时降级）
SKILL_PACK_GIT_URL=https://gitee.com/hashstacs/feishu-skills.git


# Feishu test credentials — copy this file to .env and fill in real values.
# Env vars take precedence over values in test data JSON files.
# Placeholder values like cli_xxx, ou_xxx, xxx are detected and ignored.

# === Required for layer1 / layer2 / layer3 ===
TEST_FEISHU_APP_ID=cli_xxxxxxxxxxxxxxxx
TEST_FEISHU_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TEST_FEISHU_USER_OPEN_ID=ou_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# === Required for layer4 (group chat) ===
TEST_FEISHU_GROUP_CHAT_ID=oc_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# === Optional runner overrides ===
# TEST_DATA_DIR=test/feishu-simulator/test-data/feishu-skills-layer2
# TEST_CONCURRENCY=1
# TEST_REPLY_TIMEOUT=120000
# TEST_POLL_INTERVAL=2000

# === Layer 3 only (LLM Judge) ===
# LLM_JUDGE_API_KEY=sk-ant-xxx
# LLM_JUDGE_PROVIDER=anthropic
# LLM_JUDGE_MODEL=claude-haiku-4-5-20251001


# -----------------------------------------------------------------------------
# Auth security
# -----------------------------------------------------------------------------

# ---- SMTP (enables email-based password reset + email verification) ----
# Both HOST and FROM must be set to enable email capabilities.
#ENCLAWS_SMTP_HOST=smtp.example.com
#ENCLAWS_SMTP_PORT=465
#ENCLAWS_SMTP_SECURE=true
#ENCLAWS_SMTP_USER=noreply@example.com
#ENCLAWS_SMTP_PASS=your-smtp-password-or-auth-code
#ENCLAWS_SMTP_FROM=noreply@example.com
# Optional display name in the From header (e.g. "EnClaws Security Team")
#ENCLAWS_SMTP_FROM_NAME=EnClaws

# ---- Public base URL ----
# Used to build clickable links in password-reset and email-verification emails.
# Without this, emails will contain relative URLs that can't be clicked from mail clients.
#ENCLAWS_PUBLIC_BASE_URL=https://your-domain.com

# ---- Temp password / MFA secret encryption key ----
# Used to encrypt one-time view link payloads and MFA TOTP secrets at rest.
# If unset, an ephemeral per-process key is generated (lost on restart).
# Generate with: openssl rand -hex 32
#ENCLAWS_TEMP_PW_KEY=

# ---- Password expiry policy (Phase 2) ----
# Set to 90 for 等保 2.0 Level 3 compliance. Default 0 = disabled.
#PASSWORD_MAX_AGE_DAYS=0
# Days before expiry to show the warning banner. Default 14.
#PASSWORD_WARN_DAYS_BEFORE=14

# ---- Login attempts retention (Phase 2) ----
# How many days to keep login_attempts rows before cleanup. Default 90.
#LOGIN_ATTEMPTS_RETAIN_DAYS=90

# ---- Email verification (Phase 3) ----
# When true, newly registered users must verify their email before logging in.
# Requires SMTP to be configured. Default false.
#ENCLAWS_REQUIRE_EMAIL_VERIFY=false

# ---- Admin emergency rescue ----
# Set to 1 to regenerate all platform-admin passwords on next gateway start.
# The temporary password is printed to stdout once. Remove after use.
#ENCLAWS_ADMIN_RESET=0

# ---- Custom weak-password blacklist (optional) ----
# Path to a JSON array or newline-delimited file of additional weak passwords.
# The built-in list (~430 entries) is always loaded; this extends it.
#ENCLAWS_WEAK_PASSWORDS_FILE=

# ---- Plan upgrade contact link (SaaS quota errors) ----
# When set, quota-exceeded error messages (in management UI toasts and
# IM channel replies) will include a clickable link pointing here, so
# end users / admins can contact someone to upgrade their plan.
# Example: a Feishu add-friend link, a Slack DM URL, a mailto: address,
# or an internal upgrade page.
#ENCLAWS_PLAN_UPGRADE_LINK=https://applink.feishu.cn/client/chat/chatter/add_by_link?link_token=2der9793-7a5d-452c-b575-1a1f6bbe540f
