# EnClaws .env example
#
# Quick start:
# 1) Copy this file to `.env` (for local runs from this repo), OR to `~/.enclaws/.env` (for launchd/systemd daemons).
# 2) Fill only the values you use.
# 3) Keep real secrets out of git.
#

# -----------------------------------------------------------------------------
# Gateway auth + paths
# -----------------------------------------------------------------------------
# Recommended if the gateway binds beyond loopback.
OPENCLAW_GATEWAY_TOKEN=change-me-to-a-long-random-token
# Example generator: openssl rand -hex 32

# Optional alternative auth mode (use token OR password).
OPENCLAW_GATEWAY_PASSWORD=change-me-to-a-strong-password

# Optional path overrides (defaults shown for reference).
OPENCLAW_STATE_DIR=~/.enclaws
OPENCLAW_HOME=~

# Optional: import missing keys from your login shell profile.
# OPENCLAW_LOAD_SHELL_ENV=1
# OPENCLAW_SHELL_ENV_TIMEOUT_MS=15000

# -----------------------------------------------------------------------------
# Multi-tenant database (PostgreSQL)
# -----------------------------------------------------------------------------
# Required for multi-tenant mode. If not set, runs in single-tenant (legacy) mode.
#OPENCLAW_DB_URL=postgresql://postgres:postgres@localhost:5432/enclaws
#OPENCLAW_DB_HOST=localhost
#OPENCLAW_DB_PORT=5432
#OPENCLAW_DB_NAME=postgres
#OPENCLAW_DB_USER=postgres
#OPENCLAW_DB_PASSWORD=postgres
#OPENCLAW_DB_SSL=false
#OPENCLAW_DB_POOL_MAX=20

#升级配置npm镜像源
OPENCLAW_NPM_REGISTRY=
#升级配置npm镜像包名
OPENCLAW_NPM_PACKAGE=


# sqlite数据库
OPENCLAW_DB_URL=sqlite:///tmp/sqlite/enclaws.db
# GATEWAY默认端口号
OPENCLAW_GATEWAY_PORT=18888

# Control UI 配置
# 禁用设备身份验证 (true/false, 默认 true)
OPENCLAW_CONTROL_UI_DISABLE_DEVICE_AUTH=true
# 允许的浏览器来源 (逗号分隔, 默认基于 OPENCLAW_GATEWAY_PORT 自动生成)
OPENCLAW_CONTROL_UI_ALLOWED_ORIGINS=http://localhost:18888,http://127.0.0.1:18888

#跟LLM交互的prompt跟踪开关配置
OPENCLAW_TRACE_ENABLED=true

#禁用局域网服务发现
OPENCLAW_DISABLE_BONJOUR=1

# -----------------------------------------------------------------------------
# JWT Authentication (required for multi-tenant mode)
# -----------------------------------------------------------------------------
OPENCLAW_JWT_SECRET=change-me-to-a-long-random-secret
# Example generator: openssl rand -hex 64
OPENCLAW_JWT_ACCESS_EXPIRES=30m
OPENCLAW_JWT_REFRESH_EXPIRES=7d

# -----------------------------------------------------------------------------
# Model provider API keys (set at least one)
# -----------------------------------------------------------------------------
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# GEMINI_API_KEY=...
# OPENROUTER_API_KEY=sk-or-...
# OPENCLAW_LIVE_OPENAI_KEY=sk-...
# OPENCLAW_LIVE_ANTHROPIC_KEY=sk-ant-...
# OPENCLAW_LIVE_GEMINI_KEY=...
# OPENAI_API_KEY_1=...
# ANTHROPIC_API_KEY_1=...
# GEMINI_API_KEY_1=...
# GOOGLE_API_KEY=...
# OPENAI_API_KEYS=sk-1,sk-2
# ANTHROPIC_API_KEYS=sk-ant-1,sk-ant-2
# GEMINI_API_KEYS=key-1,key-2

# Optional additional providers
# ZAI_API_KEY=...
# AI_GATEWAY_API_KEY=...
# MINIMAX_API_KEY=...
# SYNTHETIC_API_KEY=...

# -----------------------------------------------------------------------------
# Channels (only set what you enable)
# -----------------------------------------------------------------------------
# TELEGRAM_BOT_TOKEN=123456:ABCDEF...
# DISCORD_BOT_TOKEN=...
# SLACK_BOT_TOKEN=xoxb-...
# SLACK_APP_TOKEN=xapp-...

# Optional channel env fallbacks
# MATTERMOST_BOT_TOKEN=...
# MATTERMOST_URL=https://chat.example.com
# ZALO_BOT_TOKEN=...
# OPENCLAW_TWITCH_ACCESS_TOKEN=oauth:...

# -----------------------------------------------------------------------------
# Tools + voice/media (optional)
# -----------------------------------------------------------------------------
# BRAVE_API_KEY=...
# PERPLEXITY_API_KEY=pplx-...
# FIRECRAWL_API_KEY=...

# ELEVENLABS_API_KEY=...
# XI_API_KEY=...  # alias for ElevenLabs
# DEEPGRAM_API_KEY=...
