{
  "skillsDir": "D:/web3/feishu-skills",
  "env": { "FEISHU_APP_ID": "cli_xxx", "FEISHU_APP_SECRET": "xxx" },
  "vars": { "OPEN_ID": "ou_xxx" },
  "cases": [
    {
      "name": "搜索群组",
      "command": "node ./feishu-chat/chat.js --open-id {{OPEN_ID}} --action search --query 测试",
      "assert": { "exitCode": 0, "jsonPath": { "action": { "equals": "search" }, "reply": { "exists": true } } },
      "tags": ["P1"]
    },
    {
      "name": "错误-搜索缺少query",
      "command": "node ./feishu-chat/chat.js --open-id {{OPEN_ID}} --action search",
      "assert": { "exitCode": 1, "jsonPath": { "error": { "equals": "missing_param" } } },
      "tags": ["P1", "error"]
    },
    {
      "name": "错误-缺少open-id",
      "command": "node ./feishu-chat/chat.js --action search --query 测试",
      "assert": { "exitCode": 1, "jsonPath": { "error": { "equals": "missing_param" } } },
      "tags": ["P1", "error"]
    },
    {
      "name": "错误-get缺少chat-id",
      "command": "node ./feishu-chat/chat.js --open-id {{OPEN_ID}} --action get",
      "assert": { "exitCode": 1, "jsonPath": { "error": { "equals": "missing_param" } } },
      "tags": ["P1", "error"]
    },
    {
      "name": "错误-无效action",
      "command": "node ./feishu-chat/chat.js --open-id {{OPEN_ID}} --action invalid_xyz",
      "assert": { "exitCode": 1, "jsonPath": { "error": { "exists": true } } },
      "tags": ["P1", "error"]
    }
  ]
}
