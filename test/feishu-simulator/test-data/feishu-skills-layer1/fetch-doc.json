    {
      "name": "缺少open-id",
      "command": "node ./feishu-fetch-doc/fetch-doc.js --doc-id docx_test",
      "assert": {
        "exitCode": 1,
        "jsonPath": {
          "error": { "equals": "missing_param" }
        }
      },
      "tags": ["feishu-fetch-doc", "P0", "error"]
    }
  ]
