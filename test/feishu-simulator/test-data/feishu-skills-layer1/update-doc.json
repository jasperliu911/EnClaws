{
  "skillsDir": "D:/web3/feishu-skills",
  "env": {
    "FEISHU_APP_ID": "cli_xxx",
    "FEISHU_APP_SECRET": "xxx"
  },
  "vars": {
    "OPEN_ID": "ou_xxx"
  },
  "cases": [
    {
      "name": "缺少doc-id",
      "command": "node ./feishu-update-doc/update-doc.js --open-id {{OPEN_ID}} --markdown 测试内容",
      "assert": {
        "exitCode": 1,
        "jsonPath": {
          "error": { "equals": "missing_param" }
        }
      },
      "tags": ["feishu-update-doc", "P1", "error"]
    },
    {
      "name": "缺少open-id",
      "command": "node ./feishu-update-doc/update-doc.js --doc-id docx_test --markdown 测试",
      "assert": {
        "exitCode": 1,
        "jsonPath": {
          "error": { "equals": "missing_param" }
        }
      },
      "tags": ["feishu-update-doc", "P1", "error"]
    },
    {
      "name": "无效的mode",
      "command": "node ./feishu-update-doc/update-doc.js --open-id {{OPEN_ID}} --doc-id docx_test --mode invalid_mode",
      "assert": {
        "exitCode": 1,
        "jsonPath": {
          "error": { "equals": "invalid_mode" }
        }
      },
      "tags": ["feishu-update-doc", "P1", "error"]
    }
  ]
}
