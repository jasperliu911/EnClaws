{
  "skillsDir": "D:/web3/feishu-skills",
  "env": { "FEISHU_APP_ID": "cli_xxx", "FEISHU_APP_SECRET": "xxx" },
  "vars": { "OPEN_ID": "ou_xxx" },
  "cases": [
    {
      "name": "列出根目录",
      "command": "node ./feishu-drive/drive.js --open-id {{OPEN_ID}} --action list",
      "assert": { "exitCode": 0, "jsonPath": { "action": { "equals": "list" }, "reply": { "exists": true } } },
      "tags": ["P1"]
    },
    {
      "name": "创建文件夹",
      "command": "node ./feishu-drive/drive.js --open-id {{OPEN_ID}} --action create_folder --name AutoTest_Folder",
      "assert": { "exitCode": 0, "jsonPath": { "action": { "equals": "create_folder" }, "reply": { "contains": "创建" } } },
      "tags": ["P1"]
    },
    {
      "name": "错误-缺少action",
      "command": "node ./feishu-drive/drive.js --open-id {{OPEN_ID}}",
      "assert": { "exitCode": 1, "jsonPath": { "error": { "exists": true } } },
      "tags": ["P1", "error"]
    },
    {
      "name": "错误-缺少open-id",
      "command": "node ./feishu-drive/drive.js --action list",
      "assert": { "exitCode": 1, "jsonPath": { "error": { "equals": "missing_param" } } },
      "tags": ["P1", "error"]
    },
    {
      "name": "错误-创建文件夹缺少name",
      "command": "node ./feishu-drive/drive.js --open-id {{OPEN_ID}} --action create_folder",
      "assert": { "exitCode": 1, "jsonPath": { "error": { "equals": "missing_param" } } },
      "tags": ["P1", "error"]
    },
    {
      "name": "错误-无效action",
      "command": "node ./feishu-drive/drive.js --open-id {{OPEN_ID}} --action invalid_xyz",
      "assert": { "exitCode": 1, "jsonPath": { "error": { "exists": true } } },
      "tags": ["P1", "error"]
    }
  ]
}
