{
  "skillsDir": "D:/web3/feishu-skills",
  "env": {
    "FEISHU_APP_ID": "cli_xxx",
    "FEISHU_APP_SECRET": "xxx"
  },
  "vars": {
    "OPEN_ID": "ou_xxx"
  },
  "cases": [
    {
      "name": "缺少必填参数",
      "command": "node ./feishu-docx-download/download-doc.js --open-id {{OPEN_ID}}",
      "assert": {
        "exitCode": 1,
        "jsonPath": {
          "error": { "equals": "missing_arg" }
        }
      },
      "tags": ["P2", "error"]
    },
    {
      "name": "缺少open-id",
      "command": "node ./feishu-docx-download/download-doc.js --url https://example.com/docx/test",
      "assert": {
        "exitCode": 1,
        "jsonPath": {
          "error": { "exists": true }
        }
      },
      "tags": ["P2", "error"]
    },
    {
      "name": "无效URL",
      "command": "node ./feishu-docx-download/download-doc.js --open-id {{OPEN_ID}} --url https://not-feishu.com/invalid",
      "assert": {
        "exitCode": 1,
        "jsonPath": {
          "error": { "exists": true }
        }
      },
      "tags": ["P2", "error"]
    }
  ]
}
