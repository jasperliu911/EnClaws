{
  "skillsDir": "D:/web3/feishu-skills",
  "env": {
    "FEISHU_APP_ID": "cli_xxx",
    "FEISHU_APP_SECRET": "xxx"
  },
  "vars": {
    "OPEN_ID": "ou_xxx",
    "CHAT_ID": "oc_xxx"
  },
  "cases": [
    {
      "name": "读取群消息",
      "command": "node ./feishu-im-read/im-read.js --open-id {{OPEN_ID}} --action get_messages --chat-id {{CHAT_ID}}",
      "assert": {
        "exitCode": 0,
        "jsonPath": {
          "action": { "equals": "get_messages" },
          "reply": { "exists": true }
        }
      },
      "tags": ["feishu-im-read", "P2"]
    },
    {
      "name": "缺少action",
      "command": "node ./feishu-im-read/im-read.js --open-id {{OPEN_ID}}",
      "assert": {
        "exitCode": 1,
        "jsonPath": {
          "error": { "exists": true }
        }
      },
      "tags": ["feishu-im-read", "P2", "error"]
    },
    {
      "name": "缺少open-id",
      "command": "node ./feishu-im-read/im-read.js --action get_messages --chat-id {{CHAT_ID}}",
      "assert": {
        "exitCode": 1,
        "jsonPath": {
          "error": { "equals": "missing_param" }
        }
      },
      "tags": ["feishu-im-read", "P2", "error"]
    }
  ]
}
