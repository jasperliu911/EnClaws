      "tags": ["P1"]
    },
    {
      "name": "创建任务-模糊意图",
      "message": "帮我建个任务",
      "assert": { "minLength": 5, "notContains": "exception" },
      "tags": ["P1", "intent"]
    },
    {
      "name": "创建任务-指定负责人",
      "message": "帮我创建一个任务，标题是「准备周报」，指派给张三，本周五前完成",
      "assert": { "notContains": "exception", "minLength": 5 },
      "tags": ["P1"]
    },
    {
      "name": "完成任务",
      "message": "帮我把「完成自动化测试用例编写」这个任务标记为已完成",
      "assert": { "notContains": "error", "minLength": 2 },
      "tags": ["P1"]
    },
    {
      "name": "口语化-待办",
      "message": "我还有啥没干完的事儿来着？",
      "assert": { "notContains": "error", "minLength": 2 },
      "tags": ["P1", "intent"]
    }
  ]
