  "cases": [
    {
      "name": "创建任务-完整参数",
      "message": "帮我创建一个飞书任务：完成自动化测试用例编写，截止日期后天",
      "assert": { "containsAny": ["已创建", "创建成功", "任务"], "notContains": "error" },
