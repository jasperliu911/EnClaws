{
  "appId": "cli_xxx",
  "appSecret": "xxx",
  "userOpenId": "ou_xxx",
  "cases": [
    {
      "name": "列出云空间文件-回复质量",
      "message": "帮我看看我的飞书云空间有什么文件",
      "assert": {
        "notContains": "error",
        "minLength": 2
      },
      "llmJudge": {
        "criteria": [
          "文件列表以清晰的格式呈现（列表或表格）",
          "每个文件/文件夹包含名称和类型",
          "如果云空间为空，友好地告知用户",
          "没有暴露 folder_token、file_token 等内部 ID"
        ],
        "passThreshold": 0.75
      },
      "tags": ["P1", "quality"]
    },
    {
      "name": "创建文件夹-回复质量",
      "message": "帮我在飞书云空间创建一个文件夹叫「项目资料」",
      "assert": {
        "containsAny": ["已创建", "创建成功", "文件夹"],
        "notContains": "error"
      },
      "llmJudge": {
        "criteria": [
          "回复确认文件夹已创建",
          "回复包含文件夹名称",
          "提供了文件夹的飞书链接",
          "没有暴露 folder_token 等内部字段"
        ],
        "passThreshold": 0.75
      },
      "tags": ["P1", "quality"]
    }
  ]
}
